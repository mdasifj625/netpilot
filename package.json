{
  "name": "NetPilot",
  "version": "1.3.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.101.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~57.0.1",
    "expo-build-properties": "^57.0.3",
    "expo-constants": "~57.0.2",
    "expo-device": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-router": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "nativewind": "^5.0.0-preview.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "victory-native": "^41.26.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "~19.2.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^57.0.0",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "resolutions": {
    "lightningcss": "1.30.1"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "yarn lint && npx expo prebuild --no-install",
    "prebuild:clean": "yarn lint && npx expo prebuild --no-install --clean",
    "typecheck": "tsc --noEmit",
    "lint:js": "eslint src --fix",
    "lint:kt": "./bin/ktlint \"modules/**/*.kt\" --format",
    "lint:kt:format": "./bin/ktlint -F \"modules/**/*.kt\"",
    "lint": "yarn typecheck && yarn lint:js && yarn lint:kt",
    "format:js": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{js,mjs,json}\"",
    "format:js:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{js,mjs,json}\"",
    "format:kt": "./bin/ktlint -F \"modules/**/*.kt\"",
    "format": "yarn format:js && yarn format:kt",
    "format:check": "yarn format:js:check && yarn lint:kt",
    "release": "npx expo run:android --variant release && adb install app-release.apk"
  },
  "private": true
}
